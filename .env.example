# ─────────────────────────────────────────────────────────────────────────────
# Webey — Example environment configuration
# Copy relevant values into your server environment (Apache SetEnv, Nginx
# fastcgi_param, cPanel Environment Variables, or a local .env loader).
# These are PLACEHOLDERS — never commit real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=webey_local
DB_USER=root
DB_PASS=

# ── Email (SMTP / Brevo) ─────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your_smtp_login
SMTP_PASSWORD=your_smtp_password
BREVO_API_KEY=your_brevo_api_key
MAIL_FROM_EMAIL=no-reply@your-domain.example
MAIL_FROM_NAME=Webey
MAIL_DEBUG=false

# ── SMS provider (netgsm | iletimerkezi | verimor) ───────────────────────────
SMS_PROVIDER=netgsm
SMS_DEBUG=true
NETGSM_USERCODE=your_usercode
NETGSM_PASSWORD=your_password
NETGSM_MSGHEADER=WEBEY

# ── Payments (iyzico) — also see webey-site/_iyzico_config.php.example ────────
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxxxxxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=http://localhost
